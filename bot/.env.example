# Bot Configuration
# Copy to .env and fill in values

# Google Meet link to join
MEET_URL=https://meet.google.com/xxx-yyyy-zzz

# Bot display name in meeting
BOT_NAME=AI Assistant

# Server WebSocket URL
WS_URL=ws://localhost:8080/ws/realtime

# Google account credentials (for authenticated join)
# Leave empty for anonymous join (if meeting allows)
GOOGLE_EMAIL=
GOOGLE_PASSWORD=

# Audio settings
SAMPLE_RATE=16000
CHUNK_DURATION_MS=1000

# Browser settings
HEADLESS=true
