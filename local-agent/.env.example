# Local Agent Configuration

# AI Server
WS_URL=ws://localhost:8080/ws/realtime

# Audio capture source (PulseAudio/PipeWire)
# Use "auto" to auto-detect monitor source, or specify exact name
# Find sources: pactl list short sources
AUDIO_SOURCE=auto

# Overlay UI
UI_PORT=3000

# Audio settings
SAMPLE_RATE=16000
CHUNK_DURATION_MS=1000

# Features
ENABLE_TRANSLATE=true
TRANSLATE_TO=en
ENABLE_SUGGEST=true
