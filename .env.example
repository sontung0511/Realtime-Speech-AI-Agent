# Environment Configuration
# Copy this file to .env and edit values as needed

# Server
PORT=8080

# STT Provider: mock | whisper | deepgram
STT_PROVIDER=mock

# LLM Provider: mock | openai
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# Database
DB_PATH=data/speech_agent.db

# Audio limits
MAX_AUDIO_PAYLOAD=1048576
MAX_SESSION_DURATION=3600
